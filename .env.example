# Runtime
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=<64-byte-hex-string>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=900
REFRESH_TOKEN_EXPIRE_SECONDS=604800
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback
GITHUB_TOKEN_ENCRYPTION_KEY=<fernet-key-base64>
FRONTEND_ORIGIN=http://localhost:5173
INTERNAL_SERVICE_SECRET=<64-byte-hex-string>

# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agent-ops-v1
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_ORG_ID=
LANGSMITH_PROJECT_ID=
LANGSMITH_REVIEW_QUEUE_ID=
LANGSMITH_WEBHOOK_SECRET=
LANGSMITH_QUALITY_RULE_ID=
LANGSMITH_COST_RULE_ID=
LANGSMITH_ERROR_RULE_ID=

# External APIs
TAVILY_API_KEY=
GITHUB_TOKEN=<pat-for-repo-indexing>
GITHUB_WEBHOOK_SECRET=

# Agent Gateway
GATEWAY_TOKEN_INVESTIGATOR=
GATEWAY_TOKEN_CODEBASE_SEARCH=
GATEWAY_TOKEN_WEB_SEARCH=
GATEWAY_TOKEN_CRITIC=
GATEWAY_TOKEN_WRITER=

# Chroma
CHROMA_PERSIST_DIR=/data/chroma

# Job Limits
DEFAULT_COST_BUDGET_USD=0.20
