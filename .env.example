# Copy to .env and set OPENAI_API_KEY at minimum.
# DATABASE_URL and REDIS_URL are overridden by docker-compose.yml,
# so the localhost defaults here work for local dev too.

ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://agentops:agentops@localhost:5432/agentops
REDIS_URL=redis://localhost:6379/0

# Auth (dev-safe defaults — change for production)
JWT_SECRET=dev-jwt-secret-not-for-production-use-change-me-please-64-bytes!!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=900
REFRESH_TOKEN_EXPIRE_SECONDS=604800
FRONTEND_ORIGIN=http://localhost:5173
INTERNAL_SERVICE_SECRET=dev-internal-secret-not-for-production!!

# GitHub OAuth — only needed for GitHub login
# Create at: github.com → Settings → Developer settings → OAuth Apps → New
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Only needed if storing user GitHub tokens for write-back
GITHUB_TOKEN_ENCRYPTION_KEY=

# LLM — you MUST set at least OPENAI_API_KEY
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE-ME
# Get from: console.anthropic.com/settings/keys (optional, for eval judge)
ANTHROPIC_API_KEY=

# LangSmith (optional — for tracing and evals)
# Get all values from: smith.langchain.com → Settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agent-ops-v1
LANGSMITH_API_KEY=
LANGSMITH_ORG_ID=
LANGSMITH_PROJECT_ID=
# Create at: LangSmith → Annotation Queues, copy ID from URL
LANGSMITH_REVIEW_QUEUE_ID=
# Create at: LangSmith → Settings → Webhooks
LANGSMITH_WEBHOOK_SECRET=
# Create at: LangSmith → Rules, copy IDs from URL
LANGSMITH_QUALITY_RULE_ID=
LANGSMITH_COST_RULE_ID=
LANGSMITH_ERROR_RULE_ID=

# External APIs (optional)
# Get from: app.tavily.com → API Keys (needed for web search agent)
TAVILY_API_KEY=
# GitHub PAT with repo read — for codebase indexing
# Create at: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=
# Any random string — must match the value in your GitHub repo webhook config
GITHUB_WEBHOOK_SECRET=

# Agent Gateway (optional — shared secrets you make up for agent auth)
GATEWAY_TOKEN_INVESTIGATOR=
GATEWAY_TOKEN_CODEBASE_SEARCH=
GATEWAY_TOKEN_WEB_SEARCH=
GATEWAY_TOKEN_CRITIC=
GATEWAY_TOKEN_WRITER=

# Chroma
CHROMA_PERSIST_DIR=/data/chroma

# Job Limits
DEFAULT_COST_BUDGET_USD=0.20
